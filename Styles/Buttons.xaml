        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <!--  Border 承载颜色，黑色图作为 OpacityMask  -->
                        <Border
                            x:Name="Icon"
                            Width="30"
                            Height="30"
                            RenderTransformOrigin="0.5,0.5">
